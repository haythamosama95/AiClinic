# Bootstrap administrator credentials for first-time clinic setup (V1-1 auth/RBAC).
# Copy to bootstrap_admin.env for local overrides; never commit real secrets.
#
# Used by: backend/supabase/migrations/*_auth_rbac_seed.sql (Phase 2)
# Reference: specs/002-auth-rbac/quickstart.md, docs/setup/bootstrap-admin.md (Phase 11)

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_FULL_NAME=Clinic Administrator
